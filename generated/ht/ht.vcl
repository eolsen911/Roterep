.9-12.1c-1.6-5.8-1.9-12.4 2.5-16.9 1.4.8 2.4 2.3 3.5 3.4l4.9 5.4-.3 1.2c-3.1 2.2-6.2 5.4-9.2 7.7-.7.6-1.3-.3-1.4-.8zm-86-10c-5.3-5.6-11.3-10.3-16.3-16l-.6-.1c-7.2 4.2-12.4 11-14.7 19-1.1 3.6-1.3 7.5-.6 11.2 1.8 9.1 11.1 14 18.9 16.4 1-.5 1.8-1.3 2.4-2.2 4.2-2 6.2-4.9 10.2-7.1-1-1.7-2.2-3.2-3.8-4.4-1.6 1.8-4 3-6 4.9l-.9.2c-2.9-1.1-5.6-2.9-7.8-5.1-.5-.5.1-1.2.4-1.7 6.5-4.7 12.8-10.3 18.8-15.1zm-21.8 11.8c-1.2-.4-1.4-1.9-1.8-3-1.4-6.1.3-10.9 3.1-15.6l1 .3c2.9 2.9 5.4 5.5 8.6 8.3.2.5.2 1.1-.1 1.6-3.9 2.6-7 5.7-10.8 8.4zm-302 9c-1.3-.3-1.9-1.5-2.8-2.4-.1-9.5 0-19 .7-28.4-2-1.2-4.1-2.1-6.3-2.7-2.8-1.5-5.6-2.6-8.6-3.6-7.6 2.7-13.8 8.4-17 15.8-1.7 3.9-2.4 8.1-1.9 12.3-.7 5.9 3.5 11.7 8.3 15.2 1.9.7 3.6 2.3 5.6 3 3.1-1.4 5.8-3.7 9.1-5.3 4-3.2 5.1 3 8.1 4.4l9.6-5.8.1-.4-2.7-2.6c-.7-.9-1.3.8-2.2.5zm-11.6-2.8c-1.8 1.2-4 2.5-6 3.7-3.9-.1-6.9-3.1-8.9-6.1-2.7-5.9-3.9-14.5.5-20.4 1.7-1.7 2.6-5.1 5.4-4l9.2 4.3c.2 7.4-.1 15-.2 22.5zm134.3-1.7c0-4 .1-8.5 0-12.3-.2-4.1.5-9.1.2-13.5-5.5-2.2-10.6-4.7-16.1-6.9-10.2 4.9-18.5 16.1-17.7 27.4-.4 6.8 4.6 12.9 10.1 17.1l1.8.7c4.9-1.7 9.8-3.5 14.7-5.1l6 5.1c2.1-2.4 4.3-4.7 6.6-6.9-1.7-1.6-3.5-3.1-5.4-4.5l-.2-1.1zm-8.8 2.2c-1.3 1.5-4.2 2-6.2 2.5-5.7-1.2-8.8-7.2-10.5-12.1-2.3-6.8 1-12.7 5.7-17.1 2.1 0 3.8 1.5 5.7 2 1.9.5 3.8 1.3 5.4 2.4-.1 7.9-.2 14.5-.1 22.3z"/>
