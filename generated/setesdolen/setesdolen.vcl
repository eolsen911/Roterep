        d="M35.2,26.6c0,1.1.5,2,1.1,2.9.6.7,1.9,1.1,2.8.4.5-.4.8-.8,1-1.3,0-.1,0-.3,0-.5-.2-1-.3-1.9-.5-2.9,0-.2,0-.3.2-.4.3-.1.6-.2.9-.3,1-.3,2-.3,3.1,0,.4.1.8.3,1.2.5,1,.6,1.2,1.5,1.1,2.6,0,.5,0,1.1-.3,1.5s-.4.8-.8,1.2c-1,1.1-2.3,1.6-3.8,1.9s-2,.4-3,.3c-.9,0-1.8-.2-2.7-.4-1-.2-2-.5-3-.9-1.1-.5-2.1-1.1-2.8-2.1-.8-1.1-1.2-2.2-1.5-3.5-.2-.9-.1-1.8-.2-2.6h.1v-1.3c0-.3.1-.6.2-.9.4-1.4,1.2-2.5,2.1-3.5s2.1-1.7,3.4-2c1-.3,2.1-.5,3.2-.6,1-.1,2.1.1,3.1.4,1,.3,1.9.7,2.7,1.3.6.4,1.1,1,1.5,1.5.5.6.8,1.3,1.1,2.1.2.6,0,1.3,0,1.9,0,0,0,.1,0,.1-.4.2-.8.6-1.3.7-1.3.4-2.5.7-3.8,1.1-1.3.3-2.5.7-3.8,1,0,0-.2,0-.3.1-.8,0-1.1.8-1,1.7ZM35.5,21.3c.4.1.8.1,1.2,0,.8-.2,1.5-.4,2.1-.9,0-.1.2-.2.2-.3.2-.5.2-1.1,0-1.6,0-.9-.8-1.8-1.8-2-.4-.1-.7,0-1,.3-.9,1-1.2,2.2-1.3,3.5,0,.2,0,.4,0,.6.1.3.2.3.4.4Z"
      />
      <path
        d="M5.6,22.9c.5.2,1.1.3,1.6.5.3.1.6.3.9.5.7.4,1.3.9,2,1.4.2.1.2.3.2.5-.1.5-.2,1-.3,1.5-.2.6,0,1.1.2,1.6.2.3.5.6.7.9.3.3.7.4,1.2.5.8.1,1.5.1,2.2-.2.6-.2,1.3-.5,1.8-.9s1-1,.8-1.8c.2-.6-.2-.9-.5-1.3-.8-.9-1.8-1.3-2.9-1.6-2.4-.8-4.8-1.6-7.2-2.5-.7-.3-1.4-.6-2.1-1,0-.1-.2-.1-.3-.2-.5-.6-1-1.3-1.3-2-.4-1-.6-1.9-.6-2.8v-.4c0-.3,0-.5,0-.8,0-1,.3-1.9.6-2.9,0-.2.2-.3.3-.5.7-1.1,1.6-2,2.7-2.7.2-.2.5-.3.8-.4.7-.3,1.4-.6,2.3-.7h.5c.6,0,1.2,0,1.8.2,2.2.4,4.4.8,6.6,1.1,1.5.2,3.1.4,4.6.2.4-.1.9.3,1,.8.2,1.1,0,2.1-.4,3.1s-1,1.9-2.1,2.3c-.7.2-1.5.3-2.2.2-.9-.1-1.6-.6-2.4-1.1-1.3-.9-2.5-1.8-3.8-2.7-.4-.3-.7-.3-1.2-.1-.7.3-1,.8-1.1,1.3-.1.3.1.7.3.9.6.8,1.5,1.2,2.4,1.5,2,.6,4,1.2,6,1.9,1.6.5,3.1,1.1,4.4,2.2.5.4,1,1,1.3,1.5.5.8.8,1.7.9,2.7.3,1.5-.2,2.8-.6,4.2-.1.4-.5.7-.7,1.1-.3.6-.8,1-1.4,1.3-1.5,1.1-3.3,1.6-5.1,1.9-2.2.4-4.5.3-6.8.3s-2.6-.2-3.9-.5h-.6c-.9-.6-2-.8-2.9-1.4s-1.7-1.3-2.1-2.3c-.2-.5-.2-1.2-.2-1.7,0-1,.4-2,1.1-2.7,1.1-.8,2.2-1.2,3.4-.9Z"
      />
    </g>
  </g>
</svg>
</div></div><div class="articles"><div class="article" id="dr-fallback"><div class="headline"><h1 class="title">Setesdølen: Vi jobber med å gjenopprette normal drift</h1><img src=""></div><div class="article-body"><p class="text-item">Nettstedet vårt er midlertidig utilgjengelig. Avisen jobber fortløpende med å rette feilen og få publiseringen tilbake til normal drift.</p><p class="text-item">Vi oppdaterer denne siden så snart vi har ny informasjon. Takk for tålmodigheten.</p><p class="text-item">Sist oppdatert: 02.06.2026, 08:35.</p></div><ul class="table-of-contents"><li><a href="#dr-fallback">Setesdølen: Vi jobber med å gjenopprette normal drift</a></li><li><a href="#OkEPak">Utvidar leilegheitsplanar i sentrum</a></li><li><a href="#8p90Ew">Opnar for døgnskjenking under VM</a></li><li><a href="#16jJgX">Sjåføren måtte kaste seg ut av bilen</a></li><li><a href="#16jJ1X">Bilbrann stengte riksveg 9</a></li><li><a href="#Wv7Krk">Stasleg sykkelrittstart i Valle</a></li><li><a href="#K8PAde">Folkefest på Rysstad</a></li><li><a href="#y58d7A">Taubanegata 19 har fått ny eigar. Dette kosta bustaden.</a></li><li><a href="#2pPz44">–BPA for eldre</a></li><li><a href="#OkE93E">Nye hytteeigar i Murtetjønnvegen. Prisen er 940.000 kroner.</a></li><li><a href="#OkE2gl">Dei køyrer i 45 km/t og får kjeft på vegen</a></li></ul></div><div class="article" id="OkEPak"><div class="headline"><h1 class="title">Utvidar leilegheitsplanar i sentrum</h1><img src="data:image/webp; base64,"></div><div class="article-body"><div></div><div class="text-item lead-text">Bjørnero Invest AS vil bygge 23 nye leilegheiter like ved Evje sentrum. </div><p class="text-item">I 2021 fekk utbyggar Bjørnero Invest AS ved Asbjørn Haugen rammeløyve til leilegheitsbygget med 18 einingar og næringslokale i 1. etasje. Sidan er næringsdelen fjerna. </p><p class="text-item">Leilegheitsbygget i Ljosheimvegen 6 skal gå over fire etasjar i tillegg til parkeringskjellar. </p><p class="text-item"><strong class="markup style-strong">Utbyggar har søkt om dispensasjon frå krava om næring i 1. etasje, maks 18 leilegheiter og tosidig fasadeløysing.</strong></p><p class="text-item">Kommunedirektøren gjekk imot søknaden i si innstilling til planutvalet i Evje og Hornnes. </p><p class="text-item">Han viser til at kravet om næring i 1. etasje skal bidra til ein meir aktiv sentrumsdel. Målet er å styrke handel, tenester og sosiale møteplassar.</p><p class="text-item"><strong class="markup style-strong">Kommunedirektøren meiner difor at ein dispensasjon vil vere eit brot med føresetnadene i planen.</strong></p><p class="text-item">– Planen er utforma med sikte på å etablere eit aktivt og utadretta gateplan som bidrar til aktivitet og opphald, og styrkjer sentrumsfunksjonane i området, skriv kommunedirektøren.</p><div class="text-item heading">Vil unngå tomme næringslokale</div><p class="text-item">Utbyggar meiner kravet kan føre til tomme lokale og eit mindre berekraftig bymiljø. Samstundes vil prosjektet gi fleire og meir varierte bustader, og vere lettare å gjennomføre.</p><div></div><p class="text-item">Fleirtalet (V, H og KrF) i planutvalet meiner prosjektet er meir realistisk, betre tilpassa marknaden, og vil redusere risikoen for tomme næringslokale. Dei peikar også på at bustadene i 1. etasje vender mot eit indre gårdsrom, slik at området mot gata framleis framstår ope.</p><p class="text-item">Utvalet meiner også at prosjektet vil bidra til fleire bustader og større variasjon i bustadtypar i området, utan at det bryt med hovudintensjonen i reguleringsplanen. Trass i at nokre leilegheiter ikkje oppfyller kravet om tosidig fasadeløysing, blir bukvaliteten vurdert som tilfredsstillande.</p><p class="text-item">Ap og Sp kom med forslag om å starte ei omregulering av heile planområdet, men dette fekk ikkje fleirtal. </p><p class="text-item"><strong class="markup style-strong">Vedtaket om å gje dispensasjon vart så fatta mot tre røyster frå Torgeir Hodne (Ap), Egil Kvitne (Ap) og Søren Hodne (Sp).</strong></p><p class="text-item">Det er ikkje kome merknader frå naboar eller offentlege instansar i saka.</p></div></div><div class="article" id="8p90Ew"><div class="headline"><h1 class="title">Opnar for døgnskjenking under VM</h1><img src="data:image/webp; base64,"></div><div class="article-body"><div></div><div class="text-item lead-text">Serveringsstader med alminneleg skjenkeløyve i Bykle kan søke om å få skjenke alkohol heile døgnet under fotball-VM 2026.</div><p class="text-item">Kommunestyret vedtok dette med 7 mot 6 røyster under sist kommunestyremøte. </p><p class="text-item">Løyvet gjeld berre når serveringsstaden viser direktesende VM-kampar, og berre for alkoholhaldige drikkevarer under 22 prosent. Serveringsstadene må i forkant søke kommunen og oppgi kva netter dei ønskjer å halde langope, og kor lenge.</p><p class="text-item">Dei som stemte for forslaget var politikarane frå Høgre og Arbeidarpartiet, samt Anne Karin Blix Grimestad (Uavhengig). Kommunestyrerepresentantane frå Venstre, Senterpartiet, KrF og Bygdelista stemte mot.</p><p class="text-item">Anne Karin Blix Grimestad kom med eit tilleggsforslag om utvida skjenkekontroll hos stadene som viser kampane. Forslaget fall med 8 mot 5 røyster.</p></div></div><div class="article" id="16jJgX"><div class="headline"><h1 class="title">Sjåføren måtte kaste seg ut av bilen</h1><img src="data:image/webp; base64,"></div><div class="article-body"><div></div><div class="text-item lead-text">Bubilen var raskt i full fyr i vegbanen ved Skåmedal på riksveg 9. Sløkkingsarbeidet er no fullført. </div><p class="text-item">Fredrik Langfeldt frå Setesdal Brannvesen rykka ut til ulukka ved Skåmedal i Bygland kommune. </p><p class="text-item">- Det var ein bubil som begynte å brenne i vegen. Han som køyrte bilen kom seg ut og ringte etter hjelp, og så rykka vi ut frå Bygland og Byglandsfjord med to mannskapsbilar. Då vi kom fram, var bilen overtent. Vi sette i gong sløkking for å få slått ned varmen og fekk kjølt han, slik at han no er klar for å bli henta av bilbergingsbil, seier Langfeldt.</p><p class="text-item">Han opplyser at så vidt dei veit var det snakk om berre ein involvert person, og dei er ikkje kjent med noko skade hos vedkommande. </p><p class="text-item">Han bekreftar vidare at det er for tidleg å seie noko om årsak til hendinga. </p><div></div><div></div><div></div></div></div><div class="article" id="16jJ1X"><div class="headline"><h1 class="title">Bilbrann stengte riksveg 9</h1><img src="data:image/webp; base64,"></div><div class="article-body"><div></div><div class="text-item lead-text">Ein bubil har tatt fyr og sperrer det eine køyrefeltet på Rv9 ved Skåmedal. </div><p class="text-item">Politiet fekk melding om brannen klokka 12.21 måndag. Ole Robert Strandhagen i Agder politidistrikt opplyste at trafikken stod stille i begge retningar.</p><p class="text-item">Brannvesenet var framme på staden 12.37 og starta sløkking av den overtente bubilen.</p><p class="text-item">12.59 melder politiet om at alle naudetatar er på plass og at brannvesenet er i gong med ettersløkking. – Ikkje meldt om personskade på staden. Bilberging bestilt for å fjerne bubilen, melder oppdragsleiar Mats Ingebrigtsen.</p><p class="text-item">Siste melding opplyser om at trafikken no blir dirigert forbi i eitt køyrefelt.</p></div></div><div class="article" id="Wv7Krk"><div class="headline"><h1 class="title">Stasleg sykkelrittstart i Valle</h1><img src="data:image/webp; base64,"></div><div class="article-body"><div></div><div></div><div class="text-item lead-text">Over 1200 syklistar stilte til start ved havna i Kristiansand då Color Line Tour kunne markere 40-årsjubileum. Dei siste 55 kilometerane deltok også eit eige «ordførarlag», med standsmessig start i Valle.</div><div></div><p class="text-item">På dette laget var det ein god miks av dei folkevalde frå Agder: ordførarar, varaordførarar, fylkesordførar og ikkje minst ein stortingsrepresentant. Politikarlaget sykla nemleg under stødig leiing av visepresident i Stortinget, Alf Erik Andersen, saman med gode hjelparar frå Kristiansands Cykleklubb.</p><p class="text-item">Ordførarlaget starta i Valle sentrum, klare for å tråkke seg oppover dei snaue seks mila til målstreken på Hovden. </p><p class="text-item">Kva type sykkel dei valde, var ikkje hovudfokuset. Her var målet å fremje folkehelse og få fleire til å kome seg ut. Difor var både landevegsykkel og el-sykkel brukt.

Politikarane hadde ikkje mange vekene på å gjere seg klar til rittet, og det var svært varierende kor vande dei var med å sitje på sykkelsetet.</p><p class="text-item">– Nei, det er i grunnen berre kjeften som får dagleg trening, kom det frå Arne Thomassen.</p><div></div><div class="text-item heading">Kulturell fortropp</div><p class="text-item">Eit kulturelt innslag sette sitt preg på jubileumsmarkeringa til det populære sykkelrittet. Ordførarlaget stilte difor med ein staseleg fortropp av både følgje-motorsykkel og setesdalsbunad.</p><p class="text-item">Torleiv Jansen og dottera Hege Silje Trydal Jansen vart eit syn for seg sjølve langs riksveg 9 denne dagen, då dei sykla eit par kilometer i det som kunne minne om ein kulturell prosesjon.</p><p class="text-item">Begge har tilbakelagt mange mil på sykkel tidlegare, men var spente på korleis glatte bunadsko på pedalane og hovudplagg i friske vindkast ville påverke syklinga.</p><div></div><div></div></div></div><div class="article" id="K8PAde"><div class="headline"><h1 class="title">Folkefest på Rysstad</h1><img src="data:image/webp; base64,"></div><div class="article-body"><div></div><div class="text-item lead-text">For andre gong vart festivalen Hylstringen arrangert ved Sølvgarden Hotell på Rysstad. Her samla folk seg til både kurs, marknad og konsertar.</div><p class="text-item">Hylstringen oppstod som resultat av eit ønske om å skape folkefest på Rysstad, slik som den vidgjetne Setesdalsmarknaden gjorde på 90- og 2000-talet. </p><p class="text-item">Og folkefest blei det. Eit variert og solid program, med folkemusikk, dans og marknad som stikkord.</p><p class="text-item">Lokale og tilreisande i alle aldrar kosa seg i sommartemperatur ved Otra, kor det var stor aktivitet med vassport heile dagen. </p><p class="text-item"></p><div></div><div class="text-item heading"> Lokalt band med musikalsk tyngde</div><p class="text-item">Eit av trekkplastera til festivalen var konsert med bandet Vairfast. Dei spelte både på dagtid og kveldstid på laurdagen.</p><p class="text-item">–  Me er eit proft uproft band, smiler Jan Rysstad. Han snakkar om det relativt nye bandet Vairfast, som hadde sin aller fyrste konsert under fjorårets Hylstringen.</p><p class="text-item">Bandet, med sju lokale medlemmar, får viser verkeleg kva Valle kommune kan skilte med av musikalske talent.</p><div></div><p class="text-item">–  Me har øvingar gong eller to i veka, og har det veldig moro saman. Songtekstane våre er skrive av Marianne Solbakk og Elin Rysstad. Me speler også fleire av dei gamle slagarane frå Valle Radios Byljeband, fortel han. Sjølv er han å finne bak mikrofonen, i likskap med Eldbjørg Trydal Rysstad.</p><p class="text-item">Låtane deira spreidde seg raskt via Spotify, men etter at bandet bytta namn frå Hylstringen til Vairfast, forsvann låtane brått frå strøymetenesta. Det er likevel ingen grunn til panikk.</p><p class="text-item">–  Dei kjem snart attende på Spotify, forsikrar Jan.</p><div class="text-item heading">Lokale aktørar på marknaden</div><p class="text-item">Gjennom heile helga var det gode høve til å handle alt frå laftebygg til heimebakst.</p><p class="text-item">Hjå standen til Helle Lefser og Bakevare var køen jamn, og det var kanelbollar og anna småbakst som gjekk raskast unna. </p><p class="text-item">Bakaren sjølv, Gro Oddny Helle, hadde god hjelp frå både born og mann denne dagen.</p><p class="text-item">– Eg er den ulønna assistenten hennar, men eg held meg unna bakstebordet. Eg kan jo ikkje øydelegge det gode ryktet hennar, smiler ektemannen Arne. </p><p class="text-item">Heime på Helle sørger faste bestillingar og stadig aukande etterspurnad av jolelefser til at bakaromnen er meir enn velbrukt. Lefser sel dei både nært og fjernt, utan å drive stort i marknadsføring. Jungeltelegrafen tek seg av denne oppgåva.</p><p class="text-item">– Me har sendt lefser på fly til Trondheim, humrar bakaren sjølv. 
– Og til Oslo i aust og Bergen i vest. Denne marknaden verkar nærmast umetteleg.</p><div></div><div class="text-item heading">Saftsuksess på Austad</div><p class="text-item">– Salet har gått over all forventning, noko som har gjort at me allereie har turt å arbeide med neste brusvariant, fortel Torkjell Austad hjå Bygland Bakeri.</p><p class="text-item">Han har fylt opp bilen med det nyaste produktet deira, Gamabrus. Etter mange år og stor suksess med diverse ølvariantar, satsa bryggeriet fyrst på den japanske drikken sake, og deretter på brus. </p><p class="text-item">Og det er ikkje noko som blir gjort halvvegs i fabrikklokalet på Austad. Her går dei djupt ned i materien for å lage skikkelege, velsmakande produkt. I slutten av april kom Gamabrus i butikkhyllane. Blandinga av søte bringebær og syrlege rips har gjort at både store og små har fått sansen for leskedrikken.</p><p class="text-item">– Tilbakemeldingane går mykje på at brusa faktisk smakar bær. I ei tid der butikkane bugnar over av syntetiske smakar, verkar det som om dette er noko folk set pris på. Det er viktig for oss at brusa skal innehalde ekte bærpuré, fortel han.</p><div></div><p class="text-item"><em class="markup style-em">Sjå fleire bilete frå laurdagen:</em></p><div></div></div></div><div class="article" id="y58d7A"><div class="headline"><h1 class="title">Taubanegata 19 har fått ny eigar. Dette kosta bustaden.</h1><img src="data:image/webp; base64,"></div><div class="article-body"><div></div><p class="text-item">Nyleg vart salet av einebustaden med adressa Taubanegata 19 på Evje tinglyst.</p><p class="text-item">Sigbjørn Tjessem kjøpte eigedommen frå Marianne og Knut Albert Hauan for 2.050.000 kroner.</p><div class="text-item heading">64 sal i Evje</div><p class="text-item">Dei siste tolv månadane er det selt 49 andre bustadar i ein kilometers avstand frå denne eigedommen. Dyrast av desse var Alfred Skaiåsveg 28, som gjekk for 3.700.000 kroner.</p><p class="text-item">I heile Evje-området er det siste året selt 64 eigedommar. Snittpris per kvadratmeter blir 20.742 kroner. Snittet i distriktene i Agder i siste kvartal er 24.248 kroner, ifølgje Eiendom Norge.</p><p class="text-item">Dette er dei fem dyraste bustadhandlane på Evje dei siste tolv månadane:</p><ul class="list"><li class="list-item">Oddeskogen 76, 4.150.000 kroner</li><li class="list-item">Oddeskogen 18, 4.050.000 kroner</li><li class="list-item">Åmland 3, 3.700.000 kroner</li><li class="list-item">Bassengvegen 4, 3.600.000 kroner</li><li class="list-item">Oddeskogen 83, 3.500.000 kroner</li></ul><div></div></div></div><div class="article" id="2pPz44"><div class="headline"><h1 class="title">–BPA for eldre</h1><img src=""></div><div class="article-body"><p class="text-item">De politiske partier vil at eldre(over 67 år) skal bo hjemme lengst mulig. Mange klarer seg selv, andre får hjelp av familien, av venner og selvfølgelig kommunen. Hjelpebehovet er meget varierende.</p><p class="text-item">Yngre, under 67 år, har rett på Brukerstyrt personlig assistent, på visse vilkår. En ordning som kommunen innvilger og betaler.</p><p class="text-item">Hvorfor har eldre(over 67 år) IKKE den retten. Skal de eldre som vil bo hjemme, og ikke har pårørende, venner mv, som kan hjelpe dem, må kommunen trå til.</p><p class="text-item">Loven bør derfor endres, slik at eldre får de samme rettigheter, som de under 67 år. Staten bør overta finansiering av tiltaket. Vil det koste penger? JA. Hvor mye må utredes. Skal en klare å hjelpe eldre som vil, kan, og makte å bo hjemme, så er dette en løsning! Så gjenstår BARE å skaffe kvalifisert arbeidskraft</p><div class="text-item heading">Hilsen Knut Karlsen</div></div></div><div class="article" id="OkE93E"><div class="headline"><h1 class="title">Nye hytteeigar i Murtetjønnvegen. Prisen er 940.000 kroner.</h1><img src="data:image/webp; base64,"></div><div class="article-body"><div></div><p class="text-item">Eigedommen i Murtetjønnvegen 6 på Hornnes har skifta hender.</p><p class="text-item">Kjøparen Dag Naarlien Tønnessen betalte 940.000 kroner til seljar Knut Danielsen for fritidsbustaden.</p><p class="text-item">Salet vart registrert 29. mai.</p><div class="text-item heading">39 sal på Hornnes</div><p class="text-item">Salet av Murtetjønnvegen 6 er det 39. salet på Hornnes dei siste tolv månadane.</p><p class="text-item">Snittprisen er 23.677 kroner per kvadratmeter. Gjennomsnittleg pris for eigedommar er 1.700.000 kroner.</p><p class="text-item">Dette er dei fem dyraste fritidseigedommane på Hornnes det siste året:</p><ul class="list"><li class="list-item">Grastjønnvegen 100, 2.850.000 kroner</li><li class="list-item">Juvvannsvegen 22, 2.400.000 kroner</li><li class="list-item">Skranevannsvegen 10, 2.200.000 kroner</li><li class="list-item">Grastjønnvegen 70, 1.900.000 kroner</li><li class="list-item">Mathølvegen 13, 1.550.000 kroner</li></ul><div></div></div></div><div class="article" id="OkE2gl"><div class="headline"><h1 class="title">Dei køyrer i 45 km/t og får kjeft på vegen</h1><img src="data:image/webp; base64,"></div><div class="article-body"><div></div><p class="text-item">– Eg trur dei gløymer at vi har like mykje rett til å vere på vegen som dei. Vi har også ting vi skal rekke, seier Tomine Osestad Skjærstad (17).</p><p class="text-item">Ho og venninna Linea Anfinnes Hvesser (17) er frå Spangereid – eller «heilt i gokk», som dei sjølve seier.</p><p class="text-item">Før dei fekk mopedlappen, var kvardagen prega av sjeldne bussavgangar og foreldre som måtte hente og bringe.</p><p class="text-item">Mopedbilen betyr fridom til å kome seg rundt på eiga hand. Til skulen. Til jobb. Til vener. Eller ein impulstur til McDonald’s.</p><p class="text-item">I sitt nye køyretøy kan dei nytte alle vegar utanom motorveg og der det står skilt forbode.</p><div></div><p class="text-item">Men fridomen har ei bakside.</p><p class="text-item">Begge kjenner jamleg på ubehaget når bilistar legg seg tett bak, blinkar med langlysa eller tek forbikøyringar som opplevast farlege.</p><p class="text-item">– Spesielt i oppoverbakkar kokar det for folk. Vi gjer så godt vi kan, men bilen går ikkje fortare enn 45 km/t, seier Tomine.</p><p class="text-item">Linea synest det verste er når vaksne bilistar let irritasjonen gå ut over dei bak rattet.</p><p class="text-item">– Vi er ganske forsvarslause når dei som skal vere vaksne og ansvarlege, oppfører seg sånn, seier ho.</p><aside class="fact"><div class="fact-label">Fakta</div><h3 class="fact-title">Fakta om mopedbil</h3><div class="fact-items"><ul class="list"><li class="list-item">Lovendring 2019: Aldersgrensa for å køyre mopedbil blei senka frå 18 til 16 år.</li><li class="list-item">Fart: Maksimal konstruksjonshastigheit er 45 km/t. Det er ulovleg å «trimme» bilen til å gå fortare.</li><li class="list-item">Økonomi: Forbruket er svært lågt (diesel), og andrehandsverdien er ofte høg samanlikna med vanlege mopeder.</li><li class="list-item">Passasjer: Du kan ha med ein passasjer så lenge køyretøyet er registrert for det.</li><li class="list-item">Krav: Du må ha førarkort i klasse AM147. Opplæringa består av teori og praktiske timar. Det er ingen formell oppkøyring hos Statens vegvesen dersom ein tek lappen som 16-åring.</li><li class="list-item">Tryggleik: Mopedbilar har eit karosseri som beskyttar mot ver og vind, men har ikkje same kollisjonstryggleik som ein vanleg personbil.</li><li class="list-item">Mikrobilar var gruppa registrerte køyretøygruppe som auka mest det siste året.</li><li class="list-item">Mopedbilar kan ferdast på alle vegar utanom motorvegar, motortrafikkvegar og der det står skilt mot mopedbil og traktor.</li></ul></div></aside><div class="text-item heading">Blitt eit fenomen</div><p class="text-item">Linea og Tomine er langt frå åleine.</p><p class="text-item">Etter lovendringa i 2019 har mopedbilar blitt langt vanlegare blant 16-åringar.</p><p class="text-item">Særleg i distrikta har dei små køyretøya blitt eit alternativ til scooter, buss og foreldreskyss.</p><div></div><p class="text-item">For mange familiar handlar det ikkje berre om ungdommens fridom, men om kvardagslogistikk, avstandar og tryggleik.</p><p class="text-item">Samtidig er prisen høg. Ein mopedbil kostar gjerne mellom 100.000 og 200.000 kroner.</p><p class="text-item">For familiane til Linea og Tomine blei det likevel vurdert som ei god investering.</p><p class="text-item">– Det var faktisk foreldra mine som pusha mest på at eg måtte få det, seier Tomine.</p><div class="text-item heading">Foreldra pressa på</div><p class="text-item">Mora hennar, Inger Therese Osestad, fortel at tryggleiken vog tyngst.</p><p class="text-item">– Vi kjenner på mykje mindre uro sidan mopedbilen har vegger, tak, piggdekk og vern mot ver og vind, seier ho.</p><p class="text-item">Med to yngre sysken i huset vart investeringa òg lettare å forsvare. Planen er at bilen skal gå i arv.</p><div></div><p class="text-item">Også for Linea var tryggleik ein viktig grunn.</p><p class="text-item">– Syskena mine hadde hatt fleire ulukker på moped, så foreldra mine ville at eg skulle ha ein trygg måte å kome meg fram og tilbake på, seier ho.</p><p class="text-item">Ho fekk mopedbil då ho skulle flytte på internatskule.</p><p class="text-item">Sjølv om innkjøpsprisen er høg, meiner jentene at reknestykket ser litt annleis ut når bilen først er kjøpt.</p><p class="text-item">– Dieselkostnadene er mykje lågare enn på ein vanleg bil, så det er billeg å kome seg rundt. Og det er gode moglegheiter for å selje vidare, sidan det berre blir meir og meir populært, seier Linea.</p><div class="text-item heading">Filma henne frå bilen</div><p class="text-item">Men prisen er ikkje det einaste som følgjer med. For sjølv om mopedbilen gir dei ein friare kvardag, har begge opplevd situasjonar i trafikken som har sett seg.</p><p class="text-item">Den mest ubehagelege opplevinga hadde Linea nyleg, i ein seig oppoverbakke rett før eit forbikøyringsfelt.</p><p class="text-item">– Ein mann viste meg fingeren gjentekne gonger. Då forbikøyringsfeltet kom, la han seg ved sida av meg og begynte å filme meg og venninna mi. Det er sjukt at vaksne oppfører seg sånn, seier ho.</p><p class="text-item">Jentene seier dei forstår at det kan vere irriterande å hamne bak ein mopedbil. Dei veit at 45 km/t kan kjennast sakte for andre trafikantar.</p><p class="text-item">Men dei meiner det er skilnad på å bli utolmodig og å skape farlege situasjonar.</p><div></div><p class="text-item">– Vi prøver jo ikkje å irritere nokon. Vi kjem oss berre dit vi skal, seier Tomine.</p><p class="text-item">Assisterande UP-sjef Roar Skjelbred Larsen stadfestar at politiet jamleg mottek klager på aggressiv åtferd mot mopedbilar.</p><p class="text-item">Hans oppmoding til vaksne bilførarar er klar:</p><p class="text-item">– Vis tolmod, ta omsyn til kvarandre og ikkje foreta farlege forbikøyringar.</p><p class="text-item">Han minner samstundes om at mopedbilar har svakare kollisjonssikkerheit enn vanlege bilar.</p><p class="text-item">– Dei manglar ofte både airbag og moderne kollisjonssoner, og det gir ein klart auka risiko for alvorlege konsekvensar, seier Larsen.</p><div class="text-item heading">– Øydelegg for alle</div><p class="text-item">Tomine og Linea meiner òg at mopedbilistane sjølve har eit ansvar.</p><p class="text-item">– Mopedbilar som ikkje slepp andre forbi, øydelegg ryktet for oss alle. Ein må følgje med og svinge inn så fort ein har sjansen, seier Tomine bestemt.</p><p class="text-item">Samtidig meiner dei dagens fartsgrense er moden for diskusjon.</p><p class="text-item">– Hadde vi kunna køyre i 55–60 km/t, trur eg det hadde vore tryggare for alle. Litt høgare fart kunne gitt færre farlege forbikøyringar, seier ho.</p><div class="text-item heading">Musikk, McDonald’s og eigen nøkkel</div><p class="text-item">Likevel er dei ikkje i tvil om kva mopedbilen har betydd. Då lappen endeleg var i boks, var kjensla enorm.</p><p class="text-item">– Livet var berre herleg. Total eufori, minnest dei.</p><div></div><p class="text-item">Fyrste tur gjekk rett til næraste fastfood-restaurant, med passasjer i setet og musikken på full guffe.</p><p class="text-item">I starten var Lineas bil, «Sjoswe», pynta med augevipper, rattpynt og glitter.</p><p class="text-item">– No har eg fjerna alt. Det einaste eg har i bilen i dag, er rot, ler ho.</p><p class="text-item">Sjølv om bilane kanskje kan sjå litt komiske ut, er dei blitt ein viktig del av det sosiale livet. Terskelen for å dra ein stad er lågare.</p><p class="text-item">Det er enklare å besøkje vener, kome seg på jobb eller berre finne på noko spontant.</p><p class="text-item">– Det er noko heilt anna å sitje og køyre saman med ein ven. Det er her dei djupe samtalane oppstår, seier Linea.</p><p class="text-item">Jentene er heller ikkje redde for langtur. I fjor køyrde Linea strekninga frå Spangereid til Risøya, ein tur på 155 kilometer.</p><div></div><p class="text-item">I 45 kilometer i timen tek det si tid.</p><p class="text-item">– Men det gir litt roadtrip-kjensle også. Det får du ikkje på same måte på moped, seier ho.</p><div class="text-item heading">Klare for vanleg bil</div><p class="text-item">Etter nokre år på vegen begynner jentene å føle seg klare for større køyretøy.</p><p class="text-item">– I starten var det utelukkande kult med mopedbil, men no som venene mine byrjar å få lappen på vanleg bil, merkar eg at det er litt flaut å rulle rundt i denne vesle saka, innrømmer Tomine.</p><div></div><p class="text-item">Erfaringa trur dei likevel gir dei eit forsprang når dei sjølv skal ta førarkort for vanleg bil.</p><p class="text-item">Det får dei støtte i av trafikklærar Camilla Bøeng, ved Wright køyreskule.</p><p class="text-item">– Fordelen er at dei allereie har meistra mange av dei sentrale delane i trafikkopplæringa. Dei er ofte flinkare til å ta omsyn, fordi dei er vane med å vere den som må takast omsyn til, seier Bøeng.</p><div></div><p class="text-item">Samtidig meiner ho overgangen til vanleg bil krev medvit.</p><p class="text-item">– Ei ulempe er at dei kan undervurdere storleiken på køyretøyet og plassen i trafikken. Det er viktig å gjere dei medvitne om den auka risikoen ved tyngre bilar og høgare fart, seier ho.</p><p class="text-item">For Linea og Tomine har mopedbilen vore både fridom, frustrasjon og eit første møte med trafikken på eiga hand.</p><p class="text-item">No gler dei seg til neste steg. Men éin ting tek dei med seg vidare: </p><p class="text-item">– Vi kjem i alle fall til å ha meir tolmod med mopedbilar når vi sjølv køyrer vanleg bil, seier Tomine.</p></div></div></div><div></div></body></html>"} );
        return (deliver);
    }
}
