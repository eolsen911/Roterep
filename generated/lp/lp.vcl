60.3Zm-300-6.3.7.4c2.8 8.7-.3 20.4-11.9 19.7-8.1-.3-11-4.1-12.7-11.3-4.2 1.4-5 12.3-3.3 15.2 1.492 2.475 3.558 4.525 5.669 6.503l.634.592.837.78.553.52c3.399 3.21 6.465 6.533 6.907 11.506.9 9.9-2.5 15.5-11 19.9 1.8-4.6 4.5-9.2 1.4-15.2-11-11.8-17.9-29.1 2.6-45.6.383-.174.763-.36 1.143-.548l.571-.281c1.623-.793 3.29-1.52 5.286-1.371-.3 13.6 14.7 10.3 12.6-.8Zm419.6 35.5c-.8 7-2.1 16-1 23.3 1.7-1.1 4.9-3.5 6.1-5.4-.3-4.9-2.6-13.5-5.1-17.9Zm-345.4-1.8c-.9 7.3-2.1 16.6-1.1 24.1 1.7-1.2 5-3.6 6.1-5.6-.3-5.1-2.5-14-5-18.5Zm181.4-.3c0-.9-5.9 4.3-9.6 3.8-2-.3-3.2-2.3-4.6-3.4a138.45 138.45 0 0 1-.07 1.917l-.084 1.922c-.098 2.24-.173 4.462-.046 6.562.9 2.3-3.1 10.5 2.8 10.7Zm126.6 0c0-.9-5.9 4.3-9.6 3.8-2-.3-3.2-2.3-4.6-3.4a138.45 138.45 0 0 1-.07 1.917l-.084 1.922c-.098 2.24-.173 4.462-.046 6.562.9 2.3-3.1 10.5 2.8 10.7Zm-266.1-.1c0-1-5.9 4.3-9.6 3.7-1.363-.204-2.355-1.152-3.292-2.115l-.372-.385c-.31-.318-.617-.627-.936-.9a138.45 138.45 0 0 1-.07 1.917l-.084 1.922c-.098 2.24-.173 4.462-.046 6.562.9 2.3-3.1 10.5 2.8 10.7Zm163.3 8c2.2 1.1 1.4 4.5 1 6.5-.14.98-.917 1.618-1.747 2.186l-.358.24c-.239.159-.475.315-.695.475-1.582.81-3.12.414-4.607-.114l-.405-.146-.401-.148c-2.07-.76-4.037-1.394-5.887 1.108-1 .3-1.3-1-1.5-1.6-.3-3 .7-6 3.4-7.3 1.576-.852 3.08-.289 4.55.345l.572.248c1.78.766 3.515 1.377 5.278-.593l.8-1.2Zm-272.1-32.8 6.8 6.5c-2.6 2.4-4.4 4.5-5.5 7.4-1.3-2.7-4.7-6.2-8-6.6 2.4-2.2 4.4-4.7 6.7-7.3Z"
