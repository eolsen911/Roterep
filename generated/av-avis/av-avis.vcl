    d="m86.928 420.394-28.167-78.033-5.526.943-2.291 6.469 14.286 44.879H41.375l0 0h-6.2l-7.682 22.103c-2.292 6.604-4.313 9.974-9.165 10.917l-3.504.674v4.852h.674c0 0 4.717-.404 11.725-.404 9.165 0 16.711.404 16.846.404h.674v-4.852l-5.121-.674c-5.122-.809-6.065-1.888-6.065-4.313 0-1.078.27-2.426.674-3.773l6.065-19.003h26.146l5.66 16.038c.674 1.752 1.482 4.313 1.482 6.199 0 2.561-.943 4.044-5.66 4.987l-3.639.674v4.852h.674c0 0 6.334-.539 17.386-.539 9.03 0 16.173.539 16.308.539h.674v-4.852l-4.583-.674C91.106 427.133 88.545 424.706 86.928 420.394zM478.575 408.265c-.404-1.078-.943-2.022-1.617-2.831-.809-.809-1.752-1.482-2.83-1.887-2.156-.809-4.852-1.078-7.682 0-.943.404-2.021.943-3.1 1.617-.674.404-1.348.943-1.887 1.349l-.404.27c-.135.135-.27.27-.539.404v-4.583l-.943.539c0 0-.271.135-.81.404s-1.213.539-2.156.809c-1.078.404-2.156.674-3.234.943-1.348.27-2.695.539-4.043.674l-.809.135.674 2.696h.539c.943 0 1.617 0 2.156.135s.943.27 1.213.539.404.539.539.809c.135.404.135.943.135 1.482v15.095c0 .539-.135.943-.27 1.482-.135.404-.27.809-.539 1.078s-.539.539-.809.674-.674.27-1.078.404l-2.291.27v2.695l3.504-.135c.809 0 1.752 0 2.561 0 1.752 0 3.1 0 4.717 0 .81 0 1.618 0 2.292 0s1.348 0 1.752 0h1.482v-2.965l-2.695-.27c-.539 0-.809-.135-1.078-.27s-.404-.135-.404-.27c-.135-.135-.27-.404-.27-.809s-.135-.943-.135-1.752v-16.712c.404-.135.809-.27 1.348-.539.404-.135.809-.27 1.078-.539l.809-.404c.539-.27 1.213-.539 2.021-.809 1.482-.404 3.1-.404 4.178 0 .539.135.943.404 1.348.809s.674.809.809 1.348.27 1.213.27 2.021v14.286c0 .539-.135.943-.27 1.348s-.27.674-.539 1.078c-.27.27-.539.539-.943.674s-.674.27-1.078.404l-1.887.404v3.1h1.482c.404 0 1.078 0 1.887 0s1.617 0 2.426 0c1.617 0 3.1 0 4.717 0 .27 0 .539 0 .943 0v-6.199-15.499C479.114 410.421 478.979 409.208 478.575 408.265z"
