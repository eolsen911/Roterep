    call dr_site_hitra_froya_synth;
    call dr_site_ht_synth;
    call dr_site_innherred_synth;
    call dr_site_itromso_synth;
    call dr_site_klebuposten_synth;
    call dr_site_kulingen_synth;
    call dr_site_kystogfjord_synth;
