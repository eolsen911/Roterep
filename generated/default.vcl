include "vestnytt/vestnytt.vcl";
include "vigga/vigga.vcl";
include "vikebladet/vikebladet.vcl";
include "vol/vol.vcl";

sub vcl_recv {
    unset req.http.X-DR-Site;
    call dr_site_adressa_match;
    call dr_site_aesby_match;
    call dr_site_agderposten_match;
    call dr_site_altaposten_match;
    call dr_site_andalsnes_avis_match;
    call dr_site_av_avis_match;
    call dr_site_avisa_st_match;
    call dr_site_avisafroya_match;
    call dr_site_banett_match;
    call dr_site_bladet_match;
    call dr_site_bomlo_nytt_match;
    call dr_site_bygdanytt_match;
    call dr_site_dolen_match;
    call dr_site_driva_match;
    call dr_site_fjordabladet_match;
    call dr_site_fjordingen_match;
    call dr_site_fjt_match;
    call dr_site_fjuken_match;
    call dr_site_folkebladet_match;
    call dr_site_fosna_folket_match;
    call dr_site_framtidinord_match;
    call dr_site_fvn_match;
    call dr_site_gat_match;
    call dr_site_gauldalsposten_match;
    call dr_site_hallingdolen_match;
    call dr_site_hitra_froya_match;
    call dr_site_ht_match;
    call dr_site_innherred_match;
    call dr_site_itromso_match;
    call dr_site_klebuposten_match;
    call dr_site_kulingen_match;
    call dr_site_kystogfjord_match;
    call dr_site_l_a_match;
    call dr_site_lister24_match;
    call dr_site_lp_match;
    call dr_site_marsteinen_match;
    call dr_site_mn24_match;
    call dr_site_morenytt_match;
    call dr_site_nearadio_match;
    call dr_site_nyss_match;
    call dr_site_opp_match;
    call dr_site_oyposten_match;
    call dr_site_porten_match;
    call dr_site_randaberg24_match;
    call dr_site_rbnett_match;
    call dr_site_s_n_match;
    call dr_site_sandkasse_match;
    call dr_site_setesdolen_match;
    call dr_site_smp_match;
    call dr_site_steinkjer24_match;
    call dr_site_stord24_match;
    call dr_site_strilen_match;
    call dr_site_sunnhordland_match;
    call dr_site_trd_match;
    call dr_site_tronderbladet_match;
    call dr_site_vaganavisa_match;
    call dr_site_varden_match;
    call dr_site_venneslatidende_match;
    call dr_site_vestlandsnytt_match;
    call dr_site_vestnytt_match;
    call dr_site_vigga_match;
    call dr_site_vikebladet_match;
    call dr_site_vol_match;

    if (req.http.X-DR-Site) {
        return (synth(200));
    }
}

sub vcl_synth {
    call dr_site_adressa_synth;
    call dr_site_aesby_synth;
    call dr_site_agderposten_synth;
    call dr_site_altaposten_synth;
    call dr_site_andalsnes_avis_synth;
    call dr_site_av_avis_synth;
    call dr_site_avisa_st_synth;
    call dr_site_avisafroya_synth;
    call dr_site_banett_synth;
