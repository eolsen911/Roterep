    call dr_site_smp_synth;
    call dr_site_steinkjer24_synth;
    call dr_site_stord24_synth;
    call dr_site_strilen_synth;
    call dr_site_sunnhordland_synth;
    call dr_site_trd_synth;
    call dr_site_tronderbladet_synth;
    call dr_site_vaganavisa_synth;
    call dr_site_varden_synth;
    call dr_site_venneslatidende_synth;
    call dr_site_vestlandsnytt_synth;
    call dr_site_vestnytt_synth;
    call dr_site_vigga_synth;
    call dr_site_vikebladet_synth;
    call dr_site_vol_synth;
}
