-3.0662 4.8396-4.8547 7.3867-3.5772 5.0943-3.5771 5.0943 1.533 8.9149.287.143.574.366.9062.625.2593.202.5463.425.8824.649zm-42.9266-62.3907c3.6588-.3337 6.3123-2.1212 8.1446-5.5461 2.0441-3.8207 3.5771-8.1508 4.3436-12.4809 1.5331-9.9339.511-11.7169-7.4097-11.7169v-.0742h-2.2673c-.1058 0-.1678.0437-.2405.0948-.1027.0724-.2267.1598-.526.1598-1.7886 9.9339-3.5771 19.613-5.3657 29.2921 1.2776.2548 2.2996.2548 3.3216.2548zm-.8037 6.8607.0055.0743h1.533c4.0882.2547 6.6433 2.2924 7.4098 6.3678 1.533 9.9339-1.022 18.5941-7.6653 25.9808-1.7885 1.783-4.5992 2.8019-7.1542 3.0566-.5003.1662-.8917.224-1.2453.2441v-.3184c-2.5551 0-3.0661-1.2735-2.5551-4.5848.5111-3.1839 1.086-6.3042 1.6609-9.4244.5749-3.1203 1.1498-6.2406 1.6608-9.4245.7665-3.8206 1.5329-7.8957 2.2994-11.971l.0001-.0005zm-7.6598 42.0278v.329c2.0441 0 4.0881-.0637 6.1322-.1274 2.0441-.0636 4.0881-.1273 6.1322-.1273 8.6873-.2547 16.8636-3.0566 23.2513-9.4245 8.6874-8.9149 9.4539-21.6507 1.2776-30.8204-1.6671-1.6619-3.6606-2.9986-5.6965-4.3637-1.0844-.727-2.1808-1.4622-3.2463-2.2588.3747-.1868.7837-.3393 1.2019-.4953.7225-.2694 1.4724-.549 2.1197-1.033.9118-.6991 1.8813-1.3791 2.861-2.0663 2.5895-1.8161 5.2501-3.6822 7.1038-6.0845 4.5992-5.8585 4.5992-14.7734 1.2776-19.8677-4.0882-5.85843-9.7094-8.915-16.6081-8.915h-10.9546v-.07431h-36.2823c-.2555 0-.511-.00002-1.022-.25473-1.022 4.58485-.2555 5.85842 4.3437 6.36785 3.3216.50939 3.5771 1.01889 3.0661 4.33019l-11.4979 60.3672c-1.0221 6.1131-2.2996 7.3867-8.68733 7.6414-2.299583.2547-3.066126 1.5283-2.8106167 3.3113.2555087 1.5283.7665387 3.566 3.0661167 3.566z"
