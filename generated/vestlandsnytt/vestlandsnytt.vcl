
sub dr_site_vestlandsnytt_match {
    if (!req.http.X-DR-Site && req.http.host ~ ".*\.vestlandsnytt.no$") {
        set req.http.X-DR-Site = "vestlandsnytt";
    }
}

sub dr_site_vestlandsnytt_synth {
    if (req.http.X-DR-Site == "vestlandsnytt") {
        set resp.http.Content-Type = "text/html; charset=utf-8";
        set resp.http.Retry-After = "5";
        synthetic( {"<!doctype html>
<html lang="no"><head><style>html,
body {
  margin: 0;
  padding: 0;
  width: 100%;
}

:root {
