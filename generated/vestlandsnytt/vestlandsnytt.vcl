  padding-left: 5px;
  max-width: 98%;
}

.list-item::before {
  content: "●";
  color: #000724;
  margin-right: 8px;
}

.list-item {
  font-size: 18px;
  line-height: 27px;
  overflow-wrap: break-word;
  font-family:
    Publico,
    Times New Roman,
    serif;
  color: #767676;
  text-rendering: optimizeLegibility;
