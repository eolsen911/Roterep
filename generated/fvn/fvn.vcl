 .1-2.9 1.7-5.2 3.9-6.4C11.2 8.6 9 4.8 6.3 4c-.6-.2-2.1-.4-3.4.5-.8.7-1.5 2.3-.9 4.1.7 1.3 2.2 2.4 3.7 2.4zM101.6 25.1l-1 1c-.1-.1-.8-.6-.8-2.1v-7.7c0-1.8 0-3.1.8-4.1-1.5-1-3.6-2.8-4.6-4.1-2.1 1.8-4.6 3.6-6.9 4.9v11.1c0 2.8 1.4 4.3 2.4 4.9l4.2-3.5c.1 1.5 1.1 2.9 2.4 3.5l3.9-3.4-.4-.5zm-5.7-.4L94.4 26c-.6-.4-1.1-1.1-1.1-2.9V11.3l2.7 2.4v11zM51.2 7.8l-2.5-1.7C46 4.6 45.2 3.9 45.2 3c-.1-1.1.8-2 2.4-1.7l.1-.8c-1.4-.4-2.8 0-3.6.8-.6.6-1.4 2-1.1 3.9.4 1.7 1.4 2.7 3.4 3.9l1.1.7-3.4 1.7v10.9c0 1.8-.4 2.4-.8 3.1 1.7.6 4.2 2.1 5.2 3.4 1.5-1.4 4.3-3.6 6.4-4.5V13.8c-.3-2.7-.6-4.1-3.7-6zm-.5 18.3c-.6-.7-1.8-1.7-2.7-2.2V10.4c1.4.8 2.7 1.7 2.7 3.4v12.3z"
